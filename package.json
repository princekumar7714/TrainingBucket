{
  "name": "trainingbucket-fullstack",
  "private": true,
  "version": "1.0.0",
  "description": "Training Bucket - Backend + Frontend",
  "scripts": {
    "server": "node server/index.js",
    "client": "npm run dev --prefix TrainingBucket",
    "dev": "concurrently --names \"API,WEB\" -c \"blue,green\" \"npm run server\" \"npm run client\"",
    "install:all": "npm install --prefix server && npm install --prefix TrainingBucket"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
